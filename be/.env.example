# ========================
# NN Auth System — Variables de Entorno (Plantilla)
# ========================
# ¿Qué? Plantilla con TODAS las variables de entorno que necesita el backend.
# ¿Para qué? Guiar a cada desarrollador sobre qué variables configurar sin exponer datos reales.
# ¿Impacto? Sin este archivo, los nuevos desarrolladores no sabrían qué variables necesitan,
#           causando errores al iniciar la aplicación.
#
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Editar .env con valores reales para tu entorno local
# 3. NUNCA versionar el archivo .env en git

# ────────────────────────────
# 🗄️ Base de datos
# ────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=postgresql://nn_user:nn_password@localhost:5432/nn_auth_db

# ────────────────────────────
# 🔐 JWT y Seguridad
# ────────────────────────────
# Clave secreta para firmar tokens JWT — CAMBIAR en producción
# Generar una clave segura: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Algoritmo de firma JWT
ALGORITHM=HS256

# Duración del access token en minutos (15 min = sesión corta por seguridad)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token en días (7 días = una semana)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ────────────────────────────
# 📧 Email — Resend (verificación de cuenta + recuperación de contraseña)
# ────────────────────────────
# Obtener API key en: https://resend.com/api-keys
# Capa gratuita: 3,000 emails/mes — más que suficiente para desarrollo y proyectos pequeños.
# Si se deja vacío, los emails se simulan (el enlace aparece en los logs del servidor).
RESEND_API_KEY=re_your_api_key_here

# Dirección de origen de los emails.
# Para desarrollo sin dominio propio: usar "onboarding@resend.dev" (dominio de prueba de Resend).
# Para producción: usar un email de tu dominio verificado en Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=NN Auth System

# ────────────────────────────
# 📧 Email — SMTP (alternativa a Resend, sin cuenta ni dominio)
# ────────────────────────────
# ¿Qué? Si SMTP_HOST está configurado, el backend usa SMTP en lugar de Resend.
# ¿Para qué? Permite probar emails localmente con Mailpit sin cuenta ni dominio registrado.
#
# Con Docker Compose: SMTP_HOST=mailpit ya viene configurado en el docker-compose.yml
# (el servicio mailpit arranca automáticamente). Abrir http://localhost:8025 para ver emails.
#
# Para desarrollo fuera de Docker (uvicorn directo), descomentar y ajustar:
# SMTP_HOST=localhost    # Mailpit corriendo en el host
# SMTP_PORT=1025
#
# Otras opciones gratuitas para pruebas:
#   Mailtrap: SMTP_HOST=live.smtp.mailtrap.io, SMTP_PORT=587 (requiere cuenta gratuita)
#   Gmail:    SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
#             SMTP_USERNAME=tu@gmail.com
#             SMTP_PASSWORD=contraseña-de-aplicación (generada en Google Account Settings)
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=

# ────────────────────────────
# 🌐 URLs
# ────────────────────────────
# URL del frontend (para enlaces en emails de recuperación y CORS)
FRONTEND_URL=http://localhost:5173

# ────────────────────────────
# 🌍 Entorno de ejecución
# ────────────────────────────
# Controla si la documentación interactiva (/docs y /redoc) está habilitada.
# OWASP A05 — Security Misconfiguration: en producción debe ser "production"
# para deshabilitar Swagger UI y ReDoc, evitando exponer la API públicamente.
# Valores válidos: development | production | testing
ENVIRONMENT=development
